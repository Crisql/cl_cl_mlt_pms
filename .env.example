# =============================================================================
# PMS UI Migration — per-client configuration (multi-tenant by ENV)
# =============================================================================
# Each client deployment uses the SAME code with different ENV values,
# mirroring the legacy Angular src/environments/environment.{client}.ts files.
#
# Current scope: clv (Clavisco) ONLY. Other clients are added later by
# creating their own .env — NEVER hardcode client config in code.

# Base URL of the legacy .NET PMS API for this client
# clv (Clavisco): https://clpmsapi.clavisco.com  (environment.ts → ApiUrl)
LEGACY_API_URL=https://clpmsapi.clavisco.com

# Google reCAPTCHA v3 site key (environment.ts → recatpchaSiteKey)
RECAPTCHA_SITE_KEY=6LeaUewpAAAAAHZHY7-vmcndW_QiWQpdOGk1E4IX

# Login logo filename, served from app/assets/images/companiesLogo/
# (environment.ts → LoginLogo)
LOGIN_LOGO=claviscoLogin.png

# Skip SSL verification when proxying (development only)
# SKIP_SSL_VERIFICATION=true

# =============================================================================
# IMPORTANT: PROXY IS 100% TRANSPARENT
# =============================================================================
# Api::ProxyController ONLY changes the base URL of /api/* requests.
# It does NOT modify headers, authentication, or request body.
#
# The migrated UI is responsible for (replicating Angular interceptors):
#   1. Login: POST /api/token with JSON { UserName, Password }
#      + header Cl-Recaptcha-Token (reCAPTCHA v3, action "Login")
#   2. Storing the token response as base64(JSON) in localStorage "CurrentSession"
#   3. Storing the selected company as JSON in sessionStorage "SelectedCompany"
#   4. Including in every authenticated request:
#        - Authorization: Bearer {access_token}
#        - cl-company-id: {SelectedCompany.Id}   (only after company selection)
#
# See ..\acordoba_cl_cl_mlt_pms\src\app\core\interceptors\ for the reference
# implementation (AppInterceptor, RequestInterceptor, HttpAlertDecodedInterceptor).
# =============================================================================

# Nombre del ambiente mostrado en el sidebar (environment.ts -> env)
APP_ENV_NAME=Producción ambiente clavisco
