<%# Login — réplica funcional de /Login (LoginContainerComponent + cl-login CORE) %>
<%# Funcionalidad legacy: POST /api/token {UserName, Password} %>
<%# + Cl-Recaptcha-Token, guarda CurrentSession (base64) y redirige a redirectURL || /Home %>
<div class="min-h-screen flex items-center justify-center bg-gray-100"
     data-controller="login"
     data-login-redirect-value="<%= params[:redirectURL].presence || '/Home' %>"
     data-login-recaptcha-site-key-value="<%= ENV.fetch('RECAPTCHA_SITE_KEY', '') %>">

  <div class="w-full max-w-md bg-white rounded-lg shadow-md p-8">
    <div class="flex justify-center mb-6">
      <%= image_tag "companiesLogo/#{ENV.fetch('LOGIN_LOGO', 'claviscoLogin.png')}",
                    alt: "Logo", class: "max-h-24 object-contain" %>
    </div>

    <form data-action="submit->login#submit" novalidate>
      <div class="mb-4">
        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Usuario</label>
        <input type="email" id="username" name="username" autocomplete="username" required
               data-login-target="username"
               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <div class="mb-6">
        <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required
               data-login-target="password"
               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      </div>

      <button type="submit"
              data-login-target="submitButton"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded disabled:opacity-50 disabled:cursor-not-allowed">
        Iniciar sesión
      </button>
    </form>
  </div>
</div>
